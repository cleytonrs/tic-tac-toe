{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "removeComments": false
  },
  "include": [
    "game.ts", 
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules", 
    "game.js"
  ]
}
